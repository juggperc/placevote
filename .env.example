# Placevote – Environment Variables
# Copy this file to .env and fill in real values.

# ─── Clerk Authentication ─────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Neon Postgres (Drizzle ORM) ─────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/placevote?sslmode=require
VITE_DATABASE_URL=

# ─── Vercel Blob Storage ─────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Inngest & AI ──────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
OPENROUTER_API_KEY=sk-or-v1-...

VITE_API_BASE_URL=http://localhost:3001/api

# ─── Upstash Redis (Rate Limiting) ────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Map ──────────────────────────────────────────────────────────
VITE_MAPBOX_ACCESS_TOKEN=
VITE_MAP_STYLE_URL=

# ─── Feature flags ────────────────────────────────────────────────
VITE_ENABLE_ANALYTICS=false
